set(CMAKE_SYSTEM_NAME Linux)
set(CMAKE_SYSTEM_PROCESSOR aarch64)

set(ATHENA_AARCH64_TARGET "aarch64-linux-gnu" CACHE STRING "Clang target triple for Linux ARM64")
set(ATHENA_AARCH64_SYSROOT "" CACHE PATH "Optional Linux ARM64 sysroot")

set(CMAKE_C_COMPILER clang CACHE FILEPATH "")
set(CMAKE_CXX_COMPILER clang++ CACHE FILEPATH "")
set(CMAKE_C_COMPILER_TARGET "${ATHENA_AARCH64_TARGET}")
set(CMAKE_CXX_COMPILER_TARGET "${ATHENA_AARCH64_TARGET}")

find_program(ATHENA_AARCH64_LLD ld.lld)
if(ATHENA_AARCH64_LLD)
    set(CMAKE_EXE_LINKER_FLAGS_INIT "--target=${ATHENA_AARCH64_TARGET} -fuse-ld=lld")
    set(CMAKE_SHARED_LINKER_FLAGS_INIT "--target=${ATHENA_AARCH64_TARGET} -fuse-ld=lld")
    set(CMAKE_MODULE_LINKER_FLAGS_INIT "--target=${ATHENA_AARCH64_TARGET} -fuse-ld=lld")
endif()

if(ATHENA_AARCH64_SYSROOT)
    set(CMAKE_SYSROOT "${ATHENA_AARCH64_SYSROOT}")
    set(CMAKE_FIND_ROOT_PATH "${ATHENA_AARCH64_SYSROOT}")
    set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
    set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
    set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
    set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)
endif()
